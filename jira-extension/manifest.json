{
  "manifest_version": 3,
  "name": "ProgressOr – Jira Bridge",
  "version": "1.1.0",
  "description": "Routes ProgressOr's Jira requests through the extension background worker, bypassing CORS entirely.",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "https://*.jira.com/*",
    "https://gitlab.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://narchobanyan.github.io/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "cors_rules", "enabled": true, "path": "rules.json" }
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ProgressOr – Jira Bridge"
  }
}
